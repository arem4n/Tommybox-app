rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Trainer check: only by isTrainer flag in DB — no hardcoded emails
    function isTrainer() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isTrainer == true;
    }

    match /users/{userId} {
      allow read, list: if isOwner(userId) || isTrainer();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isTrainer() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['isTrainer', 'plan', 'gamification']));
      allow delete: if isTrainer();

      match /metrics/{metricId} {
        allow read: if isOwner(userId) || isTrainer();
        allow create, update, delete: if isTrainer();
      }

      match /observations/{observationId} {
        allow read: if isOwner(userId) || isTrainer();
        allow create, update, delete: if isTrainer();
      }

      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isTrainer();
        allow create, update, delete: if isTrainer();
      }

      match /feelings/{feelingId} {
        allow read: if isOwner(userId) || isTrainer();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isTrainer();
      }

      match /restrictions/{restrictionId} {
        // Trainer manages restrictions; client can only read their own
        allow read: if isOwner(userId) || isTrainer();
        allow create, update, delete: if isTrainer();
      }

      match /dailyTrackers/{date} {
        allow read: if isOwner(userId) || isTrainer();
        allow create, update: if isOwner(userId) || isTrainer();
        allow delete: if isTrainer();
      }

      // Profile photo — stored separately to keep main user doc lightweight
      match /photo/{docId} {
        allow read: if isOwner(userId) || isTrainer();
        allow write: if isOwner(userId);
      }
    }

    match /agenda/{userId}/events/{eventId} {
      allow read: if isOwner(userId) || isTrainer();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId) || isTrainer();
      allow update: if isTrainer();
    }

    match /{path=**}/events/{eventId} {
      allow read: if isTrainer();
    }

    match /bookedSlots/{slotId} {
      allow read: if isTrainer() || (isAuthenticated() && resource.data.bookedBy == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.bookedBy == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.bookedBy == request.auth.uid || isTrainer());
      allow update: if isTrainer();
    }

    match /community/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isTrainer() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited'])) ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTrainer());
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isTrainer();
    }

    // Library: clients can read, only trainer can write valid https URLs
    match /library/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isTrainer() &&
        request.resource.data.fileUrl is string &&
        request.resource.data.fileUrl.matches('https://.*');
      allow delete: if isTrainer();
    }
    // Gamification: pending achievements queue (trainer reviews)
    match /pendingAchievements/{docId} {
      allow read, delete: if isTrainer();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'type', 'createdAt']) &&
        request.resource.data.keys().hasOnly(['userId', 'type', 'description', 'createdAt']);
    }

    // Gamification: approved public achievements feed
    match /publicAchievements/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isTrainer();
    }

    // Rewards: redemption records — only owner reads own, trainer reads all
    match /redemptions/{docId} {
      allow read: if isTrainer() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isTrainer();
      allow delete: if isTrainer();
    }
  }
}
